    <Import Project="$(NuGetPackageRoot)azure.core\1.54.0\buildTransitive\net10.0\Azure.Core.targets" Condition="Exists('$(NuGetPackageRoot)azure.core\1.54.0\buildTransitive\net10.0\Azure.Core.targets')" />
    <Import Project="$(NuGetPackageRoot)microsoft.codeanalysis.analyzers\3.11.0\buildTransitive\Microsoft.CodeAnalysis.Analyzers.targets" Condition="Exists('$(NuGetPackageRoot)microsoft.codeanalysis.analyzers\3.11.0\buildTransitive\Microsoft.CodeAnalysis.Analyzers.targets')" />
    <Import Project="$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.0\build\Microsoft.AspNetCore.OpenApi.targets" Condition="Exists('$(NuGetPackageRoot)microsoft.aspnetcore.openapi\10.0.0\build\Microsoft.AspNetCore.OpenApi.targets')" />
    <Import Project="$(NuGetPackageRoot)azure.security.keyvault.secrets\4.10.0\buildTransitive\net10.0\Azure.Security.KeyVault.Secrets.targets" Condition="Exists('$(NuGetPackageRoot)azure.security.keyvault.secrets\4.10.0\buildTransitive\net10.0\Azure.Security.KeyVault.Secrets.targets')" />
  </ImportGroup>
</Project>